<Window x:Class="KeepIT.AutoArhiviranje"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Height="865"
        Width="980"
        MaxHeight="865"
        MaxWidth="980"
        MinHeight="865"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Opacity="1">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="JetBrains Mono"/>
            <Setter Property="Foreground" Value="WhiteSmoke"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="JetBrains Mono"/>
            <Setter Property="Foreground" Value="WhiteSmoke"/>
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="BorderBrush" Value="#6A6A6A"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="JetBrains Mono"/>
            <Setter Property="Foreground" Value="WhiteSmoke"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PostaviButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#040E80"/>
            <Setter Property="BorderBrush" Value="#040E80"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="JetBrains Mono"/>
            <Setter Property="Foreground" Value="WhiteSmoke"/>
        </Style>

        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="WhiteSmoke"/>
            <Setter Property="Foreground" Value="#141414"/>
            <Setter Property="Padding" Value="10,6"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0814C2"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="JetBrains Mono"/>
            <Setter Property="Background" Value="WhiteSmoke"/>
            <Setter Property="Foreground" Value="#141414"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="FontFamily" Value="JetBrains Mono"/>
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="WhiteSmoke"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="KarticeSadrzaja" TargetType="Border">
            <Setter Property="Background" Value="#202124"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#1E1E1E"
                BorderBrush="#3A3A3A"
                BorderThickness="2"
                CornerRadius="25"
                Padding="20">

            <Border Background="#242527"
                    CornerRadius="25"
                    Padding="20">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Height="40"
                          Background="Transparent"
                          MouseLeftButtonDown="TopBar_OnMouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="MinimizeButton"
                                Grid.Column="1"
                                Content="—"
                                Width="60"
                                Height="28"
                                Margin="0,0,8,0"
                                Click="MinimizeButton_Click"/>

                        <Button x:Name="BackButton"
                                Grid.Column="2"
                                Content="Back"
                                Width="60"
                                Height="28"
                                Click="BackButton_Click"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Width="900" HorizontalAlignment="Center" Margin="0,16,0,0">

                            <TextBlock Text="AUTO ARHIVIRANJE"
                                       HorizontalAlignment="Center"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Margin="0,0,0,16"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource KarticeSadrzaja}" Grid.Column="0">
                                    <StackPanel>
                                        <TextBlock Text="LOKALNO"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Margin="0,0,0,10"/>

                                        <CheckBox x:Name="LocalEnabledCheckBox"
                                                  Content="Omogućeno"
                                                  Margin="0,0,0,10"/>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Svakih" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBox x:Name="LocalIntervalValueTextBox" Width="80" Text="1"/>
                                            <ComboBox x:Name="LocalIntervalUnitComboBox"
                                                      Width="180"
                                                      Margin="10,0,0,0"
                                                      Style="{StaticResource DarkComboBox}"
                                                      Foreground="Black">
                                                <ComboBoxItem Content="Sati" Tag="Hours" Foreground="Black" Background="WhiteSmoke"/>
                                                <ComboBoxItem Content="Dani" Tag="Days" Foreground="Black" Background="WhiteSmoke"/>
                                                <ComboBoxItem Content="Tjedni" Tag="Weeks" Foreground="Black" Background="WhiteSmoke"/>
                                                <ComboBoxItem Content="Mjeseci" Tag="Months" Foreground="Black" Background="WhiteSmoke"/>
                                                <ComboBoxItem Content="Jednom" Tag="Once" Foreground="Black" Background="WhiteSmoke"/>
                                                <ComboBoxItem Content="Nikad" Tag="Never" Foreground="Black" Background="WhiteSmoke"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="Početak (opcionalno)" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <DatePicker x:Name="LocalStartDatePicker" Width="200"/>
                                        </StackPanel>

                                        <TextBlock Text="Izvori" FontWeight="Bold" Margin="0,14,0,8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button x:Name="AddLocalFolderButton" Content="Dodaj folder" Margin="0,0,8,0" Click="DodajFolderIzvorLOCAL_Click"/>
                                            <Button x:Name="AddLocalFilesButton" Content="Dodaj file" Margin="0,0,8,0" Click="DodajFileIzvorLOCAL_Click"/>
                                            <Button x:Name="RemoveLocalSourcesButton" Content="Ukloni" Click="UkloniLocalIzvore_Click"/>
                                        </StackPanel>
                                        <ListBox x:Name="LocalSourcesListBox" Height="140" SelectionMode="Extended"/>

                                        <TextBlock Text="Lokacija spremanja" FontWeight="Bold" Margin="0,14,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="LocalDestinationTextBox"/>
                                            <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0" Click="FileExZaOdabir_Click"/>
                                        </Grid>

                                        <Border Background="#141414" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,14,0,0">
                                            <StackPanel>
                                                <TextBlock x:Name="LocalSetText" FontSize="12" Text="Postavljeno: -"/>
                                                <TextBlock x:Name="LocalLastRunText" FontSize="12" Margin="0,6,0,0" Text="Zadnje izvršeno: -"/>
                                                <TextBlock x:Name="LocalNextRunText" FontSize="12" Margin="0,6,0,0" Text="Sljedeće: -"/>
                                                <TextBlock x:Name="LocalErrorText" FontSize="12" Margin="0,6,0,0" Foreground="#FFB9B9B9" TextWrapping="Wrap" Text="Greška: -"/>
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0" HorizontalAlignment="Center">
                                            <Button x:Name="SaveLocalButton" Content="Postavi lokalno" Width="190" Style="{StaticResource PostaviButton}" Click="PostaviLocalAuto_Click" Margin="0,0,10,0"/>
                                            <Button x:Name="DisableLocalButton" Content="Ukloni lokalno" Width="190" Click="UkloniLocalAuto_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource KarticeSadrzaja}" Grid.Column="2">
                                    <StackPanel>
                                        <TextBlock Text="SERVER (AZURE BLOB)"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Margin="0,0,0,10"/>

                                        <CheckBox x:Name="ServerEnabledCheckBox"
                                                  Content="Omogućeno"
                                                  Margin="0,0,0,10"/>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Svakih" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBox x:Name="ServerIntervalValueTextBox" Width="80" Text="1"/>
                                            <ComboBox x:Name="ServerIntervalUnitComboBox"
                                                      Width="180"
                                                      Margin="10,0,0,0"
                                                      Style="{StaticResource DarkComboBox}">
                                                <ComboBoxItem Content="Sati" Tag="Hours" Foreground="Black" Background="WhiteSmoke"/>
                                                <ComboBoxItem Content="Dani" Tag="Days" Foreground="Black" Background="WhiteSmoke"/>
                                                <ComboBoxItem Content="Tjedni" Tag="Weeks" Foreground="Black" Background="WhiteSmoke"/>
                                                <ComboBoxItem Content="Mjeseci" Tag="Months" Foreground="Black" Background="WhiteSmoke"/>
                                                <ComboBoxItem Content="Jednom" Tag="Once" Foreground="Black" Background="WhiteSmoke"/>
                                                <ComboBoxItem Content="Nikad" Tag="Never" Foreground="Black" Background="WhiteSmoke"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="Početak (opcionalno)" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <DatePicker x:Name="ServerStartDatePicker" Width="200"/>
                                        </StackPanel>

                                        <TextBlock Text="Izvori" FontWeight="Bold" Margin="0,14,0,8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button x:Name="AddServerFolderButton" Content="Dodaj folder" Margin="0,0,8,0" Click="DodajFolderIzvorSERVER_Click"/>
                                            <Button x:Name="AddServerFilesButton" Content="Dodaj file" Margin="0,0,8,0" Click="DodajFileIzvorSERVER_Click"/>
                                            <Button x:Name="RemoveServerSourcesButton" Content="Ukloni" Click="UkloniServerIzvore_Click"/>
                                        </StackPanel>
                                        <ListBox x:Name="ServerSourcesListBox" Height="140" SelectionMode="Extended"/>

                                        <TextBlock Text="Folder u containeru" FontWeight="Bold" Margin="0,14,0,8"/>
                                        <TextBox x:Name="ServerFolderTextBox" Text="archives/auto/"/>

                                        <TextBlock x:Name="ServerLoginText" Margin="0,10,0,0" FontSize="12" Foreground="Gray" Text="Server: -"/>

                                        <Border Background="#141414" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,14,0,0">
                                            <StackPanel>
                                                <TextBlock x:Name="ServerSetText" FontSize="12" Text="Postavljeno: -"/>
                                                <TextBlock x:Name="ServerLastRunText" FontSize="12" Margin="0,6,0,0" Text="Zadnje izvršeno: -"/>
                                                <TextBlock x:Name="ServerNextRunText" FontSize="12" Margin="0,6,0,0" Text="Sljedeće: -"/>
                                                <TextBlock x:Name="ServerErrorText" FontSize="12" Margin="0,6,0,0" Foreground="#FFB9B9B9" TextWrapping="Wrap" Text="Greška: -"/>
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0" HorizontalAlignment="Center">
                                            <Button x:Name="SaveServerButton" Content="Postavi server" Width="190" Style="{StaticResource PostaviButton}" Click="PostaviServerAuto_Click" Margin="0,0,10,0"/>
                                            <Button x:Name="DisableServerButton" Content="Ukloni server" Width="190" Click="UkloniServerAuto_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>