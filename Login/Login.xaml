<Window x:Class="KeepIT.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Height="650"
        Width="900"
        MaxHeight="650"
        MaxWidth="900"
        MinHeight="650"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="MeniKontrole" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="Foreground" Value="WhiteSmoke" />
            <Setter Property="FontFamily" Value="JetBrains Mono" />
        </Style>

        <Style x:Key="LabelStilovi" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="WhiteSmoke" />
            <Setter Property="FontFamily" Value="JetBrains Mono" />
        </Style>

        <Style x:Key="TextBoxStilovi" TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="#FF1C1C1C" />
            <Setter Property="Foreground" Value="WhiteSmoke" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
        </Style>

        <Style x:Key="PasswordBoxStilovi" TargetType="PasswordBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="#FF1C1C1C" />
            <Setter Property="Foreground" Value="WhiteSmoke" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#1E1E1E"
                BorderBrush="#3A3A3A"
                BorderThickness="2"
                CornerRadius="25"
                Padding="20">

            <Border Background="#FF242527"
                    CornerRadius="25"
                    Padding="20">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Height="40"
                          Background="Transparent"
                          MouseLeftButtonDown="TopBar_OnMouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btn_Minimize"
                                Grid.Column="1"
                                Content="—"
                                Margin="0,0,8,0"
                                Style="{StaticResource MeniKontrole}"
                                Click="MinimizeButton_Click"/>

                        <Button x:Name="btn_Close"
                                Grid.Column="2"
                                Content="X"
                                Style="{StaticResource MeniKontrole}"
                                Click="CloseButton_Click"/>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Width="360"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <TextBlock Text="LOGIN"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,30"
                                   FontSize="56"
                                   FontWeight="Bold"
                                   Foreground="WhiteSmoke"
                                   FontFamily="JetBrains Mono"/>

                        <TextBlock Text="Korisničko ime:" Style="{StaticResource LabelStilovi}"/>

                        <TextBox x:Name="txtUsername"
                                 Margin="0,6,0,18"
                                 Style="{StaticResource TextBoxStilovi}"/>

                        <TextBlock Text="Lozinka:" Style="{StaticResource LabelStilovi}"/>

                        <PasswordBox x:Name="txtPassword"
                                     Margin="0,6,0,26"
                                     Style="{StaticResource PasswordBoxStilovi}"/>

                        <Button x:Name="btn_LOGIN"
                                Content="Prijavi se"
                                Width="150"
                                Height="42"
                                HorizontalAlignment="Center"
                                Background="#040E80"
                                BorderBrush="#040E80"
                                Foreground="WhiteSmoke"
                                FontWeight="Bold"
                                FontSize="18"
                                FontFamily="JetBrains Mono"
                                Click="LoginButton_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            CornerRadius="20"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#0814C2"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#0814C2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>