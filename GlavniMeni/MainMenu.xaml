<Window x:Class="KeepIT.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KeepIT"
        mc:Ignorable="d"
        Height="650"
        Width="900"
        MaxHeight="650"
        MaxWidth="900"
        MinHeight="650"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Opacity="1">

    <Window.Resources>
        <Style x:Key="MeniKontrole" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="WhiteSmoke"/>
            <Setter Property="FontFamily" Value="JetBrains Mono"/>
        </Style>

        <Style x:Key="MeniGumbStyle" TargetType="Button">
            <Setter Property="Width" Value="250"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Background" Value="#040E80"/>
            <Setter Property="BorderBrush" Value="#040E80"/>
            <Setter Property="Foreground" Value="WhiteSmoke"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="JetBrains Mono"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                CornerRadius="20"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0814C2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0814C2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#1E1E1E"
                BorderBrush="#3A3A3A"
                BorderThickness="2"
                CornerRadius="25"
                Padding="20">

            <Border Background="#FF242527"
                    CornerRadius="25"
                    Padding="20">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Height="40"
                          Background="Transparent"
                          MouseLeftButtonDown="TopBar_OnMouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="MinimizeButton"
                                Grid.Column="1"
                                Content="—"
                                Margin="0,0,8,0"
                                Style="{StaticResource MeniKontrole}"
                                Click="MinimizeButton_Click"/>

                        <Button x:Name="CloseButton"
                                Grid.Column="2"
                                Content="X"
                                Style="{StaticResource MeniKontrole}"
                                Click="CloseButton_Click"/>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">

                        <TextBlock Text="MAIN MENU"
                                   HorizontalAlignment="Center"
                                   FontSize="56"
                                   FontWeight="Bold"
                                   Foreground="WhiteSmoke"
                                   FontFamily="JetBrains Mono"/>

                        <TextBlock x:Name="WelcomeText"
                                   Margin="0,10,0,15"
                                   FontSize="22"
                                   Foreground="LightGray"
                                   FontFamily="JetBrains Mono"
                                   HorizontalAlignment="Center"/>

                        <local:DateTimeWidget Width="94" Margin="0,10,0,0" HorizontalAlignment="Center"/>

                        <Button x:Name="ArchiveLocalButton"
                                Content="ARHIVIRAJ LOKANO"
                                Margin="0,30,0,20"
                                Style="{StaticResource MeniGumbStyle}"
                                Click="ArchiveLocalButton_Click"
                                />

                        <Button x:Name="ArchiveServerButton"
                                Content="ARHIVIRAJ SERVER"
                                Margin="0,20,0,20"
                                Style="{StaticResource MeniGumbStyle}"
                                Click="ArchiveServerButton_Click"
                                />

                        <Button x:Name="SettingsButton"
                                Content="POSTAVKE"
                                Margin="0,20,0,80"
                                Style="{StaticResource MeniGumbStyle}"
                                Click="SettingsButton_Click"
                                />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>