<Window x:Class="KeepIT.Alerts"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520" Height="260"
        MinWidth="520" MinHeight="260"
        MaxWidth="520" MaxHeight="260"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Grid>
        <Border Background="#1E1E1E"
                BorderBrush="#3A3A3A"
                BorderThickness="2"
                CornerRadius="20"
                Padding="14">

            <Border Background="#FF242527"
                    CornerRadius="18"
                    Padding="14">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- TOP BAR (drag) -->
                    <Grid Grid.Row="0"
                          Background="Transparent"
                          MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                        <TextBlock x:Name="txtTitle"
                                   Text="ALERT"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="WhiteSmoke"
                                   FontFamily="JetBrains Mono"/>
                    </Grid>

                    <!-- MESSAGE -->
                    <TextBlock x:Name="txtMessage"
                               Grid.Row="1"
                               Margin="0,10,0,10"
                               TextWrapping="Wrap"
                               FontSize="15"
                               Foreground="WhiteSmoke"
                               FontFamily="JetBrains Mono"
                               VerticalAlignment="Center"/>

                    <!-- BUTTONS -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,6,0,0">

                        <Button x:Name="btnPrimary"
                                Content="OK"
                                Width="140"
                                Height="38"
                                Margin="6,0"
                                Background="#040E80"
                                BorderBrush="#040E80"
                                Foreground="WhiteSmoke"
                                FontWeight="Bold"
                                FontSize="16"
                                FontFamily="JetBrains Mono"
                                Click="btnPrimary_Click"/>

                        <Button x:Name="btnSecondary"
                                Content="CANCEL"
                                Width="140"
                                Height="38"
                                Margin="6,0"
                                Background="#2A2A2A"
                                BorderBrush="#3A3A3A"
                                Foreground="WhiteSmoke"
                                FontWeight="Bold"
                                FontSize="16"
                                FontFamily="JetBrains Mono"
                                Visibility="Collapsed"
                                Click="btnSecondary_Click"/>

                        <Button x:Name="btnTertiary"
                                Content="ODUSTANI"
                                Width="140"
                                Height="38"
                                Margin="6,0"
                                Background="#2A2A2A"
                                BorderBrush="#3A3A3A"
                                Foreground="WhiteSmoke"
                                FontWeight="Bold"
                                FontSize="16"
                                FontFamily="JetBrains Mono"
                                Visibility="Collapsed"
                                Click="btnTertiary_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>